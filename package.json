{
  "name": "generator-spring-cli",
  "version": "0.0.1",
  "description": "CLI para geração de projetos Spring Boot via start.spring.io",
  "author": "Matheus Henrique <math.dev.contato@gmail.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "yeoman-generator",
    "builder",
    "spring-boot",
    "initializr",
    "typescript",
    "scaffold",
    "generator"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "type": "module",
  "main": "dist/generators/app/index.js",
  "files": [
    "dist/generators/app"
  ],
  "scripts": {
    "build": "tsc",
    "link": "npm run build && npm link",
    "start": "npm run link && node dist/cli.js"
  },
  "bin": {
    "spring": "./dist/cli.js"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "axios": "^1.6.0",
    "chalk": "^5.4.1",
    "enquirer": "^2.4.1",
    "fs-extra": "^11.1.1",
    "inquirer": "^9.2.1",
    "inquirer-autocomplete-prompt": "^3.0.1",
    "unzipper": "^0.12.3",
    "yeoman-generator": "^5.10.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/fs-extra": "^11.0.1",
    "@types/inquirer": "^9.0.3",
    "@types/inquirer-autocomplete-prompt": "^3.0.3",
    "@types/node": "^20.19.8",
    "@types/yeoman-generator": "^5.2.14",
    "typescript": "^5.8.3"
  }
}
